# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 对外访问地址（生成二维码链接，生产环境填正式域名）
NEXT_PUBLIC_APP_URL=http://localhost:3999

# 管理后台密码（暂不启用可留空）
ADMIN_SECRET=change-me-to-a-strong-password
# 需要密码时设为 true（须同时配置 ADMIN_SECRET）
ADMIN_REQUIRE_AUTH=false

# 定时邮件 SMTP（QQ/163/企业邮箱等）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=开拓隆海 <your-email@example.com>

# Vercel Cron 鉴权（部署后 Vercel 自动注入，本地可留空）
CRON_SECRET=change-me-cron-secret

# 业务拓展登录（/business-develop 专用，与 ADMIN_SECRET 独立）
# 会话签名密钥，至少 32 位随机字符串：openssl rand -hex 32
BUSINESS_SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# 首次创建管理员账号时需要的密钥（创建后可保留或删除）
BUSINESS_SETUP_SECRET=change-me-setup-secret

# AI 潜客爬虫（/business-develop）
# Google Custom Search：https://developers.google.com/custom-search/v1/overview
GOOGLE_CSE_API_KEY=your-google-api-key
GOOGLE_CSE_CX=your-search-engine-id
# DeepSeek：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key
# 可选，默认 deepseek-chat
DEEPSEEK_MODEL=deepseek-chat
# 未配置 Google CSE 时可用 DuckDuckGo 备用（生产环境建议 false）
LEAD_CRAWLER_ALLOW_DDG=false

# 外包需求平台 /waibao
# 会话签名密钥：openssl rand -hex 32
WAIBAO_SESSION_SECRET=change-me-waibao-session-secret-at-least-32-chars
# 首次创建管理员时需要的密钥
WAIBAO_SETUP_SECRET=change-me-waibao-setup-secret

# 供应商送货单二维码（内网收货地址，默认 http://10.88.161.250）
INTERNAL_RECEIVE_BASE_URL=http://10.88.161.250
